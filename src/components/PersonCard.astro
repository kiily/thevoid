---
import Badge from './Badge.astro';
import { Image } from 'astro:assets';

export interface Props {
	name: string;
	description: string;
	website: string;
	avatar?: ImageMetadata;
	role?: string;
	tags?: string[];
	index?: number;
}

const { name, description, website, avatar, role, tags, index = 0 } = Astro.props;

const initial = name.charAt(0).toUpperCase();

const roleLabels: Record<string, string> = {
	creator: 'Creator',
	collaborator: 'Collaborator',
	inspiration: 'Inspiration',
	community: 'Community',
};

// Generate a unique hue from the person's name for their avatar
const nameHash = name.split('').reduce((acc, char) => acc + char.charCodeAt(0), 0);
const hue = nameHash % 360;
---

<article
	class="person-card group"
	style={`--entrance-delay: ${index * 80}ms; --avatar-hue: ${hue};`}
>
	<a
		href={website}
		target="_blank"
		rel="noopener noreferrer"
		class="block p-6 rounded-lg border border-gray-200 dark:border-gray-700 transition-all duration-300 hover:border-garden-accent/40 dark:hover:border-garden-dark-accent/40 hover:-translate-y-1 hover:shadow-lg hover:shadow-garden-accent/5 dark:hover:shadow-garden-dark-accent/5"
	>
		<div class="flex items-start gap-4">
			<div class="shrink-0 avatar-wrapper">
				{avatar ? (
					<Image
						src={avatar}
						alt={name}
						width={48}
						height={48}
						class="w-12 h-12 rounded-full object-cover ring-2 ring-transparent group-hover:ring-garden-accent/30 dark:group-hover:ring-garden-dark-accent/30 transition-all duration-300"
						quality={80}
						format="webp"
					/>
				) : (
					<div
						class="w-12 h-12 rounded-full flex items-center justify-center ring-2 ring-transparent group-hover:ring-garden-accent/30 dark:group-hover:ring-garden-dark-accent/30 transition-all duration-300"
						style={`background: hsl(${hue}, 25%, 92%);`}
					>
						<span
							class="text-lg font-semibold font-ui"
							style={`color: hsl(${hue}, 40%, 40%);`}
						>
							{initial}
						</span>
					</div>
				)}
			</div>

			<div class="min-w-0 flex-1">
				<div class="flex items-center gap-2 mb-1">
					<h3 class="text-base font-semibold text-garden-primary dark:text-garden-dark-primary font-ui group-hover:text-garden-accent dark:group-hover:text-garden-dark-accent transition-colors truncate">
						{name}
					</h3>
					<svg
						class="w-4 h-4 shrink-0 text-gray-400 dark:text-gray-500 opacity-0 group-hover:opacity-100 transition-all duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						stroke-width="2"
					>
						<path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
					</svg>
				</div>

				<p class="text-sm text-body font-body leading-relaxed line-clamp-2 mb-3">
					{description}
				</p>

				<div class="flex items-center gap-2 flex-wrap">
					{role && (
						<Badge size="sm">{roleLabels[role] || role}</Badge>
					)}
					{tags && tags.slice(0, 3).map((tag) => (
						<span class="text-xs text-gray-500 dark:text-gray-400 font-ui">#{tag}</span>
					))}
				</div>
			</div>
		</div>
	</a>
</article>

<style>
	.person-card {
		opacity: 0;
		animation: fadeSlideUp 0.5s ease-out forwards;
		animation-delay: var(--entrance-delay, 0ms);
	}

	@keyframes fadeSlideUp {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Dark mode avatar colors */
	:global(.dark) .avatar-wrapper > div {
		background: hsl(var(--avatar-hue), 20%, 25%) !important;
	}

	:global(.dark) .avatar-wrapper > div > span {
		color: hsl(var(--avatar-hue), 35%, 70%) !important;
	}

	/* Respect reduced motion */
	@media (prefers-reduced-motion: reduce) {
		.person-card {
			opacity: 1;
			animation: none;
		}
	}
</style>
