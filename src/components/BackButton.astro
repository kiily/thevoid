---
interface Props {
	href: string;
	label?: string;
}

const { href, label = 'Go back' } = Astro.props;
---

<a
	href={href}
	aria-label={label}
	class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-garden-accent dark:hover:bg-garden-dark-accent hover:text-white transition-all duration-200"
>
	<svg
		xmlns="http://www.w3.org/2000/svg"
		class="w-4 h-4"
		fill="none"
		viewBox="0 0 24 24"
		stroke="currentColor"
		stroke-width="2.5"
	>
		<path
			stroke-linecap="round"
			stroke-linejoin="round"
			d="M10 19l-7-7m0 0l7-7m-7 7h18"
		/>
	</svg>
</a>
