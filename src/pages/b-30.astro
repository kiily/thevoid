		font-size: 1.25rem;
		color: var(--bdx-wine);
		margin: 0;
		opacity: 0.6;
	}
</style>

<script>
	// Password gate
	const CORRECT_PASSWORD = 'moles2026';
	const gate = document.getElementById('password-gate');
	const content = document.getElementById('b30-content');
	const form = document.getElementById('password-form');
	const input = document.getElementById('password-input') as HTMLInputElement;
	const errorEl = document.getElementById('password-error');

	function spawnConfetti() {
		const colors = [
			'#722f37',
			'#c5a55a',
			'#d4bc7c',
			'#5a1a22',
			'#e8d5a3',
			'#a04060',
		];
		const shapes = ['50%', '2px', '4px'];
		const count = 60;
		for (let i = 0; i < count; i++) {
			const el = document.createElement('div');
			el.className = 'confetti-particle';
			el.style.setProperty('--fall-duration', `${0.9 + Math.random() * 0.8}s`);
			el.style.setProperty('--fall-delay', `${Math.random() * 0.4}s`);
			el.style.setProperty(
				'--fall-rotate',
				`${Math.random() > 0.5 ? '' : '-'}${200 + Math.floor(Math.random() * 300)}deg`,
			);
			el.style.left = `${Math.random() * 100}vw`;
			el.style.width = `${6 + Math.random() * 6}px`;
			el.style.height = `${6 + Math.random() * 6}px`;
			el.style.borderRadius = shapes[Math.floor(Math.random() * shapes.length)];
			el.style.background = colors[Math.floor(Math.random() * colors.length)];
			document.body.appendChild(el);
			el.addEventListener('animationend', () => el.remove());
		}
	}

	function showWelcomeFlash() {
		const flash = document.createElement('div');
		flash.className = 'unlock-flash';
		flash.style.background = 'rgba(250,246,240,0.85)';
		const text = document.createElement('p');
		text.className = 'unlock-flash-text';
		text.textContent = 'Welcome, Moley ♥';
		flash.appendChild(text);
		document.body.appendChild(flash);
		flash.addEventListener('animationend', () => flash.remove(), {
			once: true,
		});
		text.addEventListener('animationend', () => flash.remove(), { once: true });
	}

	function unlockInstant() {
		// Already handled by CSS via html.b30-auth (inline script ran before paint)
		// This is a no-op safety net
		if (gate) gate.style.display = 'none';
		if (content) content.classList.remove('b30-content-hidden');
	}

	function unlockWithDelight() {
		spawnConfetti();
		showWelcomeFlash();

		// Animate gate out
		if (gate) {
			gate.classList.add('password-gate-exiting');
			gate.addEventListener(
				'animationend',
				() => {
					gate.style.display = 'none';
				},
				{ once: true },
			);
		}

		// Reveal content after a short delay so the flash feels intentional
		setTimeout(() => {
			if (content) {
				content.classList.remove('b30-content-hidden');
				content.classList.add('b30-content-revealed');
			}
		}, 600);
	}

	// Check session storage so users don't need to re-enter during the same session
	if (sessionStorage.getItem('b30-unlocked') === '1') {
		unlockInstant();
	}

	if (form) {
		form.addEventListener('submit', (e) => {
			e.preventDefault();
			if (input && input.value === CORRECT_PASSWORD) {
				sessionStorage.setItem('b30-unlocked', '1');
				unlockWithDelight();
			} else {
				if (errorEl) errorEl.textContent = 'Incorrect password. Try again.';
				if (input) {
					input.value = '';
					input.focus();
				}
			}
		});
	}

	const reducedMotion = window.matchMedia(
		'(prefers-reduced-motion: reduce)',
	).matches;

	// Scroll-reveal observer
	const revealElements = document.querySelectorAll('.reveal-on-scroll');

	if (!reducedMotion) {
		const revealObserver = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						entry.target.classList.add('revealed');
						revealObserver.unobserve(entry.target);
					}
				}
			},
			{ threshold: 0.15 },
		);

		for (const el of revealElements) {
			revealObserver.observe(el);
		}
	} else {
		for (const el of revealElements) {
			el.classList.add('revealed');
		}
	}

	// Scroll hint — fade out once the user scrolls past the hero
	const scrollHint = document.querySelector('.scroll-hint');
	if (scrollHint && !reducedMotion) {
		let hintHidden = false;
		window.addEventListener(
			'scroll',
			() => {
				if (!hintHidden && window.scrollY > 80) {
					scrollHint.classList.add('hidden');
					hintHidden = true;
				}
			},
			{ passive: true },
		);
	}
</script>
