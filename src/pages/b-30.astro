<style>
	/* =================================================================
	   CSS VARIABLES & FULL-BLEED WRAPPER
	   ================================================================= */
	.b30-page {
		--bdx-cream: #faf6f0;
		--bdx-cream-deep: #f2ede4;
		--bdx-wine: #722f37;
		--bdx-wine-deep: #5a1a22;
		--bdx-gold: #c5a55a;
		--bdx-gold-light: #d4bc7c;
		--bdx-ink: #2d2226;
		--bdx-ink-mid: rgba(45, 34, 38, 0.6);
		--bdx-ink-faint: rgba(45, 34, 38, 0.15);

		margin: -2rem -1.5rem;
		color: var(--bdx-ink);
		background: var(--bdx-cream);
		font-family: var(--font-serif);
		line-height: 1.7;
	}

	:global(.dark) .b30-page {
		--bdx-cream: #1a1618;
		--bdx-cream-deep: #141113;
		--bdx-wine: #c2727a;
		--bdx-wine-deep: #d4949a;
		--bdx-gold: #d4bc7c;
		--bdx-gold-light: #b89e5a;
		--bdx-ink: #e8e2d6;
		--bdx-ink-mid: rgba(232, 226, 214, 0.6);
		--bdx-ink-faint: rgba(232, 226, 214, 0.12);
	}

	@media (min-width: 768px) {
		.b30-page {
			margin-left: -3rem;
			margin-right: -3rem;
		}
	}

	@media (min-width: 1024px) {
		.b30-page {
			margin-left: -4rem;
			margin-right: -4rem;
		}
	}

	/* Selection */
	.b30-page ::selection {
		background-color: var(--bdx-wine);
		color: #fff;
	}

	:global(.dark) .b30-page ::selection {
		background-color: var(--bdx-gold);
		color: var(--bdx-cream-deep);
	}

	/* =================================================================
	   SCROLL REVEAL ANIMATION
	   ================================================================= */
	.reveal-on-scroll {
		opacity: 0;
		transform: translateY(24px);
		transition:
			opacity 0.7s ease,
			transform 0.7s ease;
	}

	.reveal-on-scroll.revealed {
		opacity: 1;
		transform: translateY(0);
	}

	/* Staggered itinerary items */
	.itinerary-item {
		opacity: 0;
		transform: translateX(-12px);
		transition:
			opacity 0.5s ease,
			transform 0.5s ease;
	}

	.revealed .itinerary-item {
		opacity: 1;
		transform: translateX(0);
	}

	.revealed .itinerary-item:nth-child(1) {
		transition-delay: 0.1s;
	}
	.revealed .itinerary-item:nth-child(2) {
		transition-delay: 0.2s;
	}
	.revealed .itinerary-item:nth-child(3) {
		transition-delay: 0.3s;
	}
	.revealed .itinerary-item:nth-child(4) {
		transition-delay: 0.4s;
	}
	.revealed .itinerary-item:nth-child(5) {
		transition-delay: 0.5s;
	}
	.revealed .itinerary-item:nth-child(6) {
		transition-delay: 0.6s;
	}

	/* Hero wine fill reveal */
	.wine-fill-path {
		clip-path: inset(100% 0 0 0);
		animation: wine-pour 2.5s 0.8s ease-out forwards;
	}

	@keyframes wine-pour {
		from {
			clip-path: inset(100% 0 0 0);
		}
		to {
			clip-path: inset(0% 0 0 0);
		}
	}

	/* "30" watermark breathing — like the Heart Sutra's enso-pulse */
	.hero-watermark {
		animation: watermark-breathe 10s 1.5s ease-in-out infinite;
	}

	@keyframes watermark-breathe {
		0% {
			opacity: 0.04;
			transform: scale(1);
		}
		40% {
			opacity: 0.025;
			transform: scale(0.97);
		}
		55% {
			opacity: 0.025;
			transform: scale(0.97);
		}
		100% {
			opacity: 0.04;
			transform: scale(1);
		}
	}

	:global(.dark) .hero-watermark {
		animation-name: watermark-breathe-dark;
	}

	@keyframes watermark-breathe-dark {
		0% {
			opacity: 0.06;
			transform: scale(1);
		}
		40% {
			opacity: 0.035;
			transform: scale(0.97);
		}
		55% {
			opacity: 0.035;
			transform: scale(0.97);
		}
		100% {
			opacity: 0.06;
			transform: scale(1);
		}
	}

	/* Wine glass gentle sway — starts after pour completes */
	.hero-motif-svg {
		animation: glass-sway 6s 3.5s ease-in-out infinite;
		transform-origin: 60px 168px; /* pivot at base */
	}

	@keyframes glass-sway {
		0% {
			transform: rotate(0deg);
		}
		25% {
			transform: rotate(1.5deg);
		}
		75% {
			transform: rotate(-1.5deg);
		}
		100% {
			transform: rotate(0deg);
		}
	}

	/* Hero divider grows from center on load */
	.hero-divider {
		animation: divider-grow 1s 0.5s ease-out both;
	}

	@keyframes divider-grow {
		from {
			width: 0;
		}
		to {
			width: 3rem;
		}
	}

	/* Scroll hint — sits at bottom of hero, gentle bounce, fades on scroll */
	.scroll-hint {
		position: absolute;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		color: var(--bdx-ink-mid);
		opacity: 0.4;
		animation: hint-bounce 2.5s 2s ease-in-out infinite;
		transition: opacity 0.5s ease;
		z-index: 1;
	}

	.scroll-hint.hidden {
		opacity: 0;
	}

	@keyframes hint-bounce {
		0%,
		100% {
			transform: translateX(-50%) translateY(0);
		}
		50% {
			transform: translateX(-50%) translateY(6px);
		}
	}

	/* Closing heart — gentle heartbeat pulse */
	.closing-heart {
		animation: heartbeat 2.5s 1s ease-in-out infinite;
	}

	@keyframes heartbeat {
		0% {
			transform: scale(1);
		}
		14% {
			transform: scale(1.15);
		}
		28% {
			transform: scale(1);
		}
		42% {
			transform: scale(1.1);
		}
		56% {
			transform: scale(1);
		}
		100% {
			transform: scale(1);
		}
	}

	/* Day theme words — delayed whisper entrance */
	.day-theme {
		opacity: 0;
		transform: translateY(4px);
		transition:
			opacity 0.6s 0.4s ease,
			transform 0.6s 0.4s ease;
	}

	.revealed .day-theme {
		opacity: 1;
		transform: translateY(0);
	}

	/* Respect reduced motion */
	@media (prefers-reduced-motion: reduce) {
		.reveal-on-scroll {
			opacity: 1;
			transform: none;
			transition: none;
		}

		.itinerary-item {
			opacity: 1;
			transform: none;
			transition: none;
		}

		.wine-fill-path {
			animation: none;
			clip-path: none;
		}

		.hero-watermark {
			animation: none;
		}

		.hero-motif-svg {
			animation: none;
		}

		.hero-divider {
			animation: none;
			width: 3rem;
		}

		.scroll-hint {
			animation: none;
			display: none;
		}

		.closing-heart {
			animation: none;
		}

		.day-theme {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}

	/* =================================================================
