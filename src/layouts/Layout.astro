---
import '../styles/global.css';
import { Font } from 'astro:assets';
// import Navigation from '../components/Navigation.astro';
import Header from '../components/Header.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

export interface Props {
	title: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	publishedTime?: string;
	modifiedTime?: string;
	author?: string;
	noindex?: boolean;
	lang?: string;
	tags?: string[];
}

const {
	title,
	description = 'A digital garden exploring web development, design, and technology.',
	image = '/og-image.jpg',
	type = 'website',
	publishedTime,
	modifiedTime,
	author = 'Miguel Marin Vermelho',
	noindex = false,
	lang = 'en',
	tags,
} = Astro.props;

const siteUrl = 'https://thevoid.garden';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = image.startsWith('http')
	? image
	: new URL(image, siteUrl).toString();

const personSchema = {
	'@type': 'Person',
	'@id': `${siteUrl}/#person`,
	name: 'Miguel Marin Vermelho',
	url: siteUrl,
	jobTitle: 'CTO',
	worksFor: { '@type': 'Organization', name: 'FLOWN' },
	sameAs: [
		'https://github.com/kiily',
		'https://www.linkedin.com/in/miguel-marin-vermelho-09805185/',
		'https://twitter.com/kiily95',
		'https://bsky.app/profile/kiily95.bsky.social',
	],
};

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	'@id': `${siteUrl}/#website`,
	name: 'The Void',
	url: `${siteUrl}/`,
	description: 'A personal digital garden by Miguel Marin Vermelho',
	author: personSchema,
	potentialAction: {
		'@type': 'SearchAction',
		target: {
			'@type': 'EntryPoint',
			urlTemplate: `${siteUrl}/api/search?q={search_term_string}`,
		},
		'query-input': 'required name=search_term_string',
	},
};

const articleSchema =
	type === 'article'
		? {
				'@context': 'https://schema.org',
				'@type': 'BlogPosting',
				headline: title,
				description,
				url: canonicalUrl,
				mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
				author: personSchema,
				publisher: personSchema,
				datePublished: publishedTime,
				dateModified: modifiedTime ?? publishedTime,
				image: ogImageUrl,
				...(tags && tags.length > 0 ? { keywords: tags.join(', ') } : {}),
			}
		: null;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/void.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />

		<link rel="dns-prefetch" href="https://va.vercel-scripts.com" />
		<link
			rel="alternate"
			type="application/rss+xml"
			title="The Void — Garden"
			href="/rss.xml"
		/>

		<!-- SEO -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1024" />
		<meta property="og:image:height" content="541" />
		<meta property="og:image:alt" content={title} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:type" content={type} />
		<meta property="og:site_name" content="The Void" />
		<meta property="og:locale" content="en_US" />
		{
			type === 'article' && publishedTime && (
				<meta property="article:published_time" content={publishedTime} />
			)
		}
		{
			type === 'article' && author && (
				<meta property="article:author" content={author} />
			)
		}

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={title} />

		<!-- Astro Font API - handles optimization automatically -->
		<Font cssVariable="--font-inter" preload />
		<Font cssVariable="--font-source-serif-4" preload />
		<Font cssVariable="--font-cormorant-garamond" preload />

		<!-- Structured Data (JSON-LD) -->
		<script
			type="application/ld+json"
			set:html={JSON.stringify(websiteSchema)}
		/>
		{
			articleSchema && (
				<script
					type="application/ld+json"
					set:html={JSON.stringify(articleSchema)}
				/>
			)
		}

		<slot name="head" />

		<!-- Theme initialization - must run before body renders to prevent flash -->
		<script is:inline>
			// Apply theme immediately on initial load (synchronous to prevent flash)
			(function () {
				var theme =
					localStorage.getItem('theme') ||
					(window.matchMedia('(prefers-color-scheme: dark)').matches
						? 'dark'
						: 'light');
				document.documentElement.classList.toggle('dark', theme === 'dark');
			})();
		</script>
	</head>
	<body class="font-body min-h-screen">
		<Header />
		<div class="flex pt-16">
			{/* <Navigation /> */}
			<main
				class="flex-1 px-6 py-8 md:px-12 lg:px-16 transition-[margin] duration-300"
			>
				<slot />
				<Analytics />
				<SpeedInsights />
			</main>
		</div>
	</body>
</html>

<style is:global>
	/* Native browser view transitions (Chrome 126+, Edge 126+, Safari 18.2+) */
	@view-transition {
		navigation: auto;
	}

	/* Base styles in @layer base so Tailwind utilities can override them */
	@layer base {
		:root {
			--font-serif: var(--font-source-serif-4), 'Source Serif 4', Georgia, serif;
			--font-sans:
				var(--font-inter), 'Inter', system-ui, -apple-system, sans-serif;
			--font-display:
				var(--font-cormorant-garamond), 'Cormorant Garamond', Georgia, serif;

			/* Theme colors as CSS custom properties for smooth transitions */
			--theme-bg: #f7f7f2;
			--theme-text: #2d3a3a;
		}

		.dark {
			--theme-bg: #1a1a1a;
			--theme-text: #e1e1e1;
		}

		html {
			scroll-behavior: smooth;
		}

		body {
			font-family: var(--font-serif);
			line-height: 1.7;
			color: var(--theme-text);
			background-color: var(--theme-bg);
			-webkit-font-smoothing: antialiased;
			-moz-osx-font-smoothing: grayscale;
			/* Transition on custom properties doesn't cause layout recalculation */
			transition:
				background-color 0.3s ease,
				color 0.3s ease;
		}

		h1,
		h2,
		h3,
		h4,
		h5,
		h6 {
			font-family: var(--font-sans);
			font-weight: 700;
			line-height: 1.15;
			margin: 0;
			letter-spacing: -0.03em;
		}

		h1 {
			font-family: var(--font-display);
			font-weight: 400;
			font-style: italic;
			font-size: clamp(2.5rem, 5vw, 3.5rem);
			letter-spacing: -0.01em;
		}

		h2 {
			font-weight: 700;
			font-size: clamp(1.75rem, 3vw, 2.25rem);
		}

		h3 {
			font-weight: 600;
			font-size: clamp(1.25rem, 2vw, 1.5rem);
		}

		h4,
		h5,
		h6 {
			font-weight: 600;
		}

		/* Section number styling */
		.section-number {
			font-family: var(--font-sans);
			font-size: 0.875rem;
			font-weight: 500;
			letter-spacing: 0.1em;
			margin-bottom: 1rem;
		}

		/* Refined link styles */
		a {
			transition:
				color 0.2s ease,
				opacity 0.2s ease;
		}

		/* Selection styling */
		::selection {
			background-color: #006400;
			color: white;
		}

		.dark ::selection {
			background-color: #90ee90;
			color: #1a1a1a;
		}
	}

	/* Badge hover styling — outside @layer so it applies reliably */
	.badge:hover,
	.badge-sm:hover {
		background-color: #006400;
		color: white;
	}

	:is(.dark) .badge:hover,
	:is(.dark) .badge-sm:hover {
		background-color: #90EE90;
	}
</style>
